# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Generate your own Django secret key:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_own_secret_key_here

# Database connection string (dj-database-url format)
# For local development with SQLite:
#   DATABASES=sqlite:///db.sqlite3
# For Postgres (e.g. hosted on Render/Railway/Supabase):
#   DATABASES=postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASES=sqlite:///db.sqlite3
